{
  "name": "project-titan",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.12.1",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "format": "prettier --write .",
    "db:generate": "pnpm --filter @titan/database prisma:generate",
    "db:migrate": "pnpm --filter @titan/database prisma:migrate",
    "db:deploy": "pnpm --filter @titan/database prisma:deploy",
    "db:studio": "pnpm --filter @titan/database prisma:studio",
    "db:seed-admin": "pnpm --filter @titan/database prisma:seed"
  },
  "devDependencies": {
    "prettier": "^3.5.3",
    "turbo": "^2.5.4",
    "typescript": "^5.8.3"
  }
}
